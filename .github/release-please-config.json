{
	"initial-version": "0.1.0",
	"include-v-in-release-name": false,
	"packages": {
		".": {
			"include-component-in-tag": false,
			"extra-files": [
				{
					"type": "json",
					"path": "package.json",
					"jsonpath": "$.version"
				},
				{
					"type": "json",
					"path": "frontend/web/package.json",
					"jsonpath": "$.version"
				},
				{
					"type": "toml",
					"path": "Cargo.toml",
					"jsonpath": "$.workspace.package.version"
				},
				{
					"type": "yaml",
					"path": "charts/Chart.yaml",
					"jsonpath": "$.version"
				},
				{
					"type": "yaml",
					"path": "charts/Chart.yaml",
					"jsonpath": "$.appVersion"
				},
				{
					"type": "json",
					"path": "api-service/openapi.json",
					"jsonpath": "$.info.version"
				}
			]
		}
	},
	"$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json"
}

	"components": {
		"schemas": {
			"CreateGroup": {
				"type": "object",
				"description": "sent to the database for creating a new group",
				"required": ["name"],
				"properties": {
					"name": {
						"type": "string",
						"minLength": 1
					}
				}
			},
			"CreateJob": {
				"type": "object",
				"description": "sent to the database for creating a new job",
				"required": ["name", "job_type_id", "group_id", "notify_users", "run_every", "details"],
				"properties": {
					"custom_notification": {
						"type": ["string", "null"]
					},
					"details": {
						"$ref": "#/components/schemas/CreateJobDetails"
					},
					"group_id": {
						"type": "string"
					},
					"job_type_id": {
						"type": "string"
					},
					"name": {
						"type": "string"
					},
					"notify_users": {
						"type": "boolean"
					},
					"run_every": {
						"type": "string"
					}
				}
			},
			"CreateJobDetails": {
				"oneOf": [
					{
						"type": "object",
						"required": ["Http"],
						"properties": {
							"Http": {
								"$ref": "#/components/schemas/CreateJobDetailsHttp"
							}
						}
					},
					{
						"type": "object",
						"required": ["Ping"],
						"properties": {
							"Ping": {
								"$ref": "#/components/schemas/CreateJobDetailsPing"
							}
						}
					}
				],
				"description": "sent to the database for creating a new job and its details"
			},
			"CreateJobDetailsHttp": {
				"type": "object",
				"description": "sent to the database for creating a new job detail",
				"required": ["url"],
				"properties": {
					"url": {
						"type": "string"

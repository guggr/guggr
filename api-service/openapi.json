{
	"openapi": "3.1.0",
	"info": {
		"title": "api-service",
		"description": "guggr HTTP API Service",
		"contact": {
			"name": "guggr"
		},
		"license": {
			"name": "GPL-3.0",
			"identifier": "GPL-3.0"
		},
		"version": "0.1.0"
	},
	"paths": {
		"/api/v1/auth/login": {
			"post": {
				"tags": ["auth"],
				"summary": "login endpoint",
				"operationId": "auth_login",
				"requestBody": {
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/LoginRequest"
							}
						}
					},
					"required": true
				},
				"responses": {
					"200": {
						"description": "Login successful",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/TokenResponse"
								}
							}
						}
					},
					"400": {
						"description": "Bad Request",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/BadRequestErrorBody"
								}
							}
						}
					},
					"500": {
						"description": "Internal Server Error"
					}
				}
			}
		},
		"/api/v1/auth/logout": {
			"post": {
				"tags": ["auth"],
				"summary": "logout endpoint",
				"operationId": "auth_logout",
				"requestBody": {
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/TokenRefreshRequest"
							}
						}
					},
					"required": true
				},
				"responses": {
					"204": {
						"description": "Successful logout"
					},
					"401": {
						"description": "Unauthorized"
					},
					"500": {
						"description": "Internal Server Error"
					}
				}
			}
		},
		"/api/v1/auth/token/refresh": {
			"post": {
				"tags": ["auth"],
				"summary": "token refresh endpoint",
				"operationId": "auth_refresh_token",
				"requestBody": {
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/TokenRefreshRequest"
							}
						}
					},
					"required": true
				},
				"responses": {
					"200": {
						"description": "Access- and refresh-token",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/TokenResponse"
								}
							}
						}
					},
					"400": {
						"description": "Bad Request",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/BadRequestErrorBody"
								}
							}
						}
					},
					"401": {
						"description": "Unauthorized"
					},
					"500": {
						"description": "Internal Server Error"
					}
				}
			}
		},
		"/api/v1/users": {
			"post": {
				"tags": ["users"],
				"summary": "Create user",
				"operationId": "create_user",
				"requestBody": {
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/CreateUser"
							}
						}
					},
					"required": true
				},
				"responses": {
					"200": {
						"description": "User successfully created",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/DisplayUser"
								}
							}
						}
					},
					"400": {
						"description": "Bad Request",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/BadRequestErrorBody"
								}
							}
						}
					},
					"500": {
						"description": "Internal Server Error"
					}
				}
			}
		}
	},
	"components": {
		"schemas": {
			"BadRequestErrorBody": {
				"type": "object",
				"description": "Bad request errors",
				"required": ["message"],
				"properties": {
					"message": {
						"type": "string"
					}
				}
			},
			"CreateUser": {
				"type": "object",
				"description": "Struct to create a new user",
				"required": ["email", "password", "name"],
				"properties": {
					"email": {
						"type": "string",
						"minLength": 1
					},
					"name": {
						"type": "string",
						"minLength": 1
					},
					"password": {
						"type": "string",
						"minLength": 1
					}
				}
			},
			"DisplayUser": {
				"type": "object",
				"description": "Returned user",
				"required": ["id", "email", "name"],
				"properties": {
					"email": {
						"type": "string"
					},
					"id": {
						"type": "string"
					},
					"name": {
						"type": "string"
					}
				}
			},
			"LoginRequest": {
				"type": "object",
				"description": "request by the user to login",
				"required": ["email", "password"],
				"properties": {
					"email": {
						"type": "string"
					},
					"password": {
						"type": "string"
					}
				}
			},
			"TokenRefreshRequest": {
				"type": "object",
				"description": "request by the user to get a new [`TokenResponse`]",
				"required": ["refresh_token"],
				"properties": {
					"refresh_token": {
						"type": "string"
					}
				}
			},
			"TokenResponse": {
				"type": "object",
				"description": "returned to the user on login / token refresh",
				"required": ["access_token", "refresh_token"],
				"properties": {
					"access_token": {
						"type": "string"
					},
					"refresh_token": {
						"type": "string"
					}
				}
			}
		},
		"securitySchemes": {
			"bearerAuth": {
				"type": "http",
				"scheme": "bearer",
				"bearerFormat": "JWT"
			}
		}
	}
}

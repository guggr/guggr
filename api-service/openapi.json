						"description": "Bad Request",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/BadRequestErrorBody"
								}
							}
						}
					},
					"500": {
						"description": "Internal Server Error"
					}
				}
			}
		},

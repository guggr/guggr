{
	"openapi": "3.1.0",
	"info": {
		"title": "api-service",
		"description": "guggr HTTP API Service",
		"contact": {
			"name": "guggr"
		},
		"license": {
			"name": "GPL-3.0",
			"identifier": "GPL-3.0"
		},
		"version": "0.3.0"
	},
	"paths": {
		"/api/v1/auth/login": {
			"post": {
				"tags": ["auth"],
				"summary": "Login",
				"operationId": "auth_login",
				"requestBody": {
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/LoginRequest"
							}
						}
					},
					"required": true
				},
				"responses": {
					"200": {
						"description": "Login successful",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/AuthenticatedResponse"
								}
							}
						}
					},
					"400": {
						"description": "Bad Request",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/BadRequestErrorBody"
								}
							}
						}
					},
					"500": {
						"description": "Internal Server Error"
					}
				}
			}
		},
		"/api/v1/auth/logout": {
			"post": {
				"tags": ["auth"],
				"summary": "Logout and invalidate the refresh tokens",
				"operationId": "auth_logout",
				"requestBody": {
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/LogoutRequest"
							}
						}
					},
					"required": true
				},
				"responses": {
					"204": {
						"description": "Logout successful"
					},
					"400": {
						"description": "Bad Request",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/BadRequestErrorBody"
								}
							}
						}
					},
					"500": {
						"description": "Internal Server Error"
					}
				}
			}
		},
		"/api/v1/auth/token/refresh": {
			"post": {
				"tags": ["auth"],
				"summary": "Renew access and refresh tokens",
				"operationId": "auth_refresh_token",
				"requestBody": {
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/TokenRefreshRequest"
							}
						}
					},
					"required": true
				},
				"responses": {
					"200": {
						"description": "Renewed access and refresh tokens",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/TokenResponse"
								}
							}
						}
					},
					"400": {
						"description": "Bad Request",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/BadRequestErrorBody"
								}
							}
						}
					},
					"500": {
						"description": "Internal Server Error"
					}
				}
			}
		},
		"/api/v1/groups": {
			"get": {
				"tags": ["groups"],
				"summary": "List groups visible by the logged in user",
				"operationId": "list_groups",
				"responses": {
					"200": {
						"description": "User",
						"content": {
							"application/json": {
								"schema": {
									"type": "array",
									"items": {
										"$ref": "#/components/schemas/DisplayGroup"
									}
								}
							}
						}
					},
					"401": {
						"description": "Unauthorized"
					},
					"404": {
						"description": "Not Found"
					},
					"500": {
						"description": "Internal Server Error"
					}
				},
				"security": [
					{
						"token": []
					}
				]
			},
			"post": {
				"tags": ["groups"],
				"summary": "Create group",
				"operationId": "create_group",
				"requestBody": {
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/CreateGroup"
							}
						}
					},
					"required": true
				},
				"responses": {
					"200": {
						"description": "Group successfully created",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/DisplayGroup"
								}
							}
						}
					},
					"400": {
						"description": "Bad Request",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/BadRequestErrorBody"
								}
							}
						}
					},
					"500": {
						"description": "Internal Server Error"
					}
				},
				"security": [
					{
						"token": []
					}
				]
			}
		},
		"/api/v1/jobs/{id}/runs": {
			"get": {
				"tags": ["jobs"],
				"summary": "list endpoint for job runs",
				"operationId": "list_job_runs",
				"parameters": [
					{
						"name": "id",
						"in": "path",
						"description": "Job ID",
						"required": true,
						"schema": {
							"type": "string"
						}
					}
				],
				"responses": {
					"200": {
						"description": "List jobs runs",
						"content": {
							"application/json": {
								"schema": {
									"type": "array",
									"items": {
										"$ref": "#/components/schemas/DisplayJobRun"
									}
								}
							}
						}
					},
					"401": {
						"description": "Unauthorized"
					},
					"404": {
						"description": "Not Found"
					},
					"500": {
						"description": "Internal Server Error"
					}
				},
				"security": [
					{
						"token": []
					}
				]
			}
		},
		"/api/v1/users": {
			"post": {
				"tags": ["users"],
				"summary": "Create user",
				"operationId": "create_user",
				"requestBody": {
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/CreateUser"
							}
						}
					},
					"required": true
				},
				"responses": {
					"200": {
						"description": "User successfully created",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/DisplayUser"
								}
							}
						}
					},
					"400": {
						"description": "Bad Request",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/BadRequestErrorBody"
								}
							}
						}
					},
					"500": {
						"description": "Internal Server Error"
					}
				}
			}
		},
		"/api/v1/users/{id}": {
			"get": {
				"tags": ["users"],
				"summary": "Get user by ID",
				"operationId": "get_user",
				"parameters": [
					{
						"name": "id",
						"in": "path",
						"description": "User ID",
						"required": true,
						"schema": {
							"type": "string"
						}
					}
				],
				"responses": {
					"200": {
						"description": "User",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/DisplayUser"
								}
							}
						}
					},
					"401": {
						"description": "Unauthorized"
					},
					"404": {
						"description": "Not Found"
					},
					"500": {
						"description": "Internal Server Error"
					}
				},
				"security": [
					{
						"token": []
					}
				]
			}
		}
	},
	"components": {
		"schemas": {
			"AuthenticatedResponse": {
				"type": "object",
				"description": "Data sent upon login.",
				"required": ["user", "auth"],
				"properties": {
					"auth": {
						"$ref": "#/components/schemas/TokenResponse"
					},
					"user": {
						"$ref": "#/components/schemas/DisplayUser"
					}
				}
			},
			"BadRequestErrorBody": {
				"type": "object",
				"description": "Bad request errors",
				"required": ["message"],
				"properties": {
					"message": {
						"type": "string"
					}
				}
			},
			"CreateGroup": {
				"type": "object",
				"description": "Struct to create a new Group",
				"required": ["name"],
				"properties": {
					"name": {
						"type": "string",
						"minLength": 1
					}
				}
			},
			"CreateUser": {
				"type": "object",
				"description": "Struct to create a new user",
				"required": ["email", "password", "name"],
				"properties": {
					"email": {
						"type": "string",
						"minLength": 1
					},
					"name": {
						"type": "string",
						"minLength": 1
					},
					"password": {
						"type": "string",
						"minLength": 1
					}
				}
			},
			"DisplayGroup": {
				"type": "object",
				"description": "Returned Group",
				"required": ["id", "name", "members"],
				"properties": {
					"id": {
						"type": "string"
					},
					"members": {
						"type": "array",
						"items": {
							"$ref": "#/components/schemas/DisplayGroupMember"
						}
					},
					"name": {
						"type": "string"
					}
				}
			},
			"DisplayGroupMember": {
				"type": "object",
				"description": "Returned user",
				"required": ["id", "name", "role"],
				"properties": {
					"id": {
						"type": "string"
					},
					"name": {
						"type": "string"
					},
					"role": {
						"type": "string"
					}
				}
			},
			"DisplayJobResultHttp": {
				"type": "object",
				"required": ["id", "ip_address", "status_code", "latency", "payload"],
				"properties": {
					"id": {
						"type": "string"
					},
					"ip_address": {
						"type": "string",
						"format": "cidr",
						"example": "192.0.2.5/32"
					},
					"latency": {
						"type": "integer",
						"format": "int32"
					},
					"payload": {
						"type": "array",
						"items": {
							"type": "integer",
							"format": "int32",
							"minimum": 0
						}
					},
					"status_code": {
						"type": "integer",
						"format": "int32"
					}
				}
			},
			"DisplayJobResultPing": {
				"type": "object",
				"required": ["id", "ip_address", "latency"],
				"properties": {
					"id": {
						"type": "string"
					},
					"ip_address": {
						"type": "string",
						"format": "cidr",
						"example": "192.0.2.5/32"
					},
					"latency": {
						"type": "integer",
						"format": "int32"
					}
				}
			},
			"DisplayJobRun": {
				"type": "object",
				"description": "Returned JobRun",
				"required": [
					"id",
					"job_id",
					"timestamp",
					"triggered_notification",
					"batch_id",
					"reachable",
					"details"
				],
				"properties": {
					"batch_id": {
						"type": "string"
					},
					"details": {
						"$ref": "#/components/schemas/DisplayJobRunDetails"
					},
					"id": {
						"type": "string"
					},
					"job_id": {
						"type": "string"
					},
					"reachable": {
						"type": "boolean"
					},
					"timestamp": {
						"type": "string",
						"format": "date-time"
					},
					"triggered_notification": {
						"type": "boolean"
					}
				}
			},
			"DisplayJobRunDetails": {
				"oneOf": [
					{
						"type": "object",
						"required": ["Http"],
						"properties": {
							"Http": {
								"$ref": "#/components/schemas/DisplayJobResultHttp"
							}
						}
					},
					{
						"type": "object",
						"required": ["Ping"],
						"properties": {
							"Ping": {
								"$ref": "#/components/schemas/DisplayJobResultPing"
							}
						}
					},
					{
						"type": "string",
						"enum": ["Undefined"]
					}
				],
				"description": "Returned JobRun details"
			},
			"DisplayUser": {
				"type": "object",
				"description": "Returned user",
				"required": ["id", "email", "name"],
				"properties": {
					"email": {
						"type": "string"
					},
					"id": {
						"type": "string"
					},
					"name": {
						"type": "string"
					}
				}
			},
			"LoginRequest": {
				"type": "object",
				"description": "Data used to authenticate.",
				"required": ["email", "password"],
				"properties": {
					"email": {
						"type": "string"
					},
					"password": {
						"type": "string"
					}
				}
			},
			"LogoutRequest": {
				"type": "object",
				"description": "Data used to logout.",
				"required": ["refresh_token"],
				"properties": {
					"refresh_token": {
						"type": "string"
					}
				}
			},
			"TokenRefreshRequest": {
				"type": "object",
				"description": "Data used to refresh the access and refresh tokens.",
				"required": ["refresh_token"],
				"properties": {
					"refresh_token": {
						"type": "string"
					}
				}
			},
			"TokenResponse": {
				"type": "object",
				"description": "Authentication tokens as received after successful authentication.",
				"required": ["access_token", "refresh_token"],
				"properties": {
					"access_token": {
						"type": "string"
					},
					"refresh_token": {
						"type": "string"
					}
				}
			}
		},
		"securitySchemes": {
			"token": {
				"type": "http",
				"scheme": "bearer",
				"bearerFormat": "JWT"
			}
		}
	}
}

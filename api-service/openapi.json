	"components": {
		"schemas": {
			"AuthenticatedResponse": {
				"type": "object",
				"description": "Data sent upon login.",
				"required": ["user", "auth"],
				"properties": {
					"auth": {
						"$ref": "#/components/schemas/TokenResponse"
					},
					"user": {
						"$ref": "#/components/schemas/DisplayUser"
					}
				}
			},
			"BadRequestErrorBody": {
				"type": "object",
				"description": "Bad request errors",
				"required": ["message"],
				"properties": {
					"message": {
						"type": "string"
					}
				}
			},
			"CreateGroup": {
				"type": "object",
				"description": "Struct to create a new Group",
				"required": ["name"],
				"properties": {
					"name": {
						"type": "string",
						"minLength": 1
					}
				}
			},
			"CreateJob": {
				"type": "object",
				"description": "Struct to create a new job",
				"required": ["name", "job_type_id", "group_id", "notify_users", "run_every", "details"],
				"properties": {
					"custom_notification": {
						"type": ["string", "null"]
					},
					"details": {
						"$ref": "#/components/schemas/CreateJobDetails"
					},
					"group_id": {
						"type": "string"
					},
					"job_type_id": {
						"type": "string"
					},
					"name": {
						"type": "string"
					},
					"notify_users": {
						"type": "boolean"
					},
					"run_every": {
						"type": "integer",
						"format": "int64",
						"default": 60
					}
				}
			},
			"CreateJobDetails": {
				"oneOf": [
					{
						"type": "object",
						"required": ["http"],
						"properties": {
							"http": {
								"$ref": "#/components/schemas/CreateJobDetailsHttp"
							}
						}
					},
					{
						"type": "object",
						"required": ["ping"],
						"properties": {
							"ping": {
								"$ref": "#/components/schemas/CreateJobDetailsPing"
							}
						}
					}
				],
				"description": "Enum to create Job Details"
			},
			"CreateJobDetailsHttp": {
				"type": "object",
				"description": "Struct to create a new Job HTTP Detail",
				"required": ["url"],
				"properties": {
					"url": {
						"type": "string"
					}
				}
			},
			"CreateJobDetailsPing": {
				"type": "object",
				"description": "Struct to create a new Job Ping Detail",
				"required": ["host"],
				"properties": {
					"host": {
						"type": "string"
					}
				}
			},
			"CreateUser": {
				"type": "object",
				"description": "Struct to create a new user",
				"required": ["email", "password", "name"],
				"properties": {
					"email": {
						"type": "string",
						"minLength": 1
					},
					"name": {
						"type": "string",
						"minLength": 1
					},
					"password": {
						"type": "string",
						"minLength": 1
					}
				}
			},
			"DisplayGroup": {
				"type": "object",
				"description": "Returned Group",
				"required": ["id", "name", "members"],
				"properties": {
					"id": {
						"type": "string"
					},
					"members": {
						"type": "array",
						"items": {
							"$ref": "#/components/schemas/DisplayGroupMember"
						}
					},
					"name": {
						"type": "string"
					}
				}
			},
			"DisplayGroupMember": {
				"type": "object",
				"description": "Returned user",
				"required": ["id", "name", "role"],
				"properties": {
					"id": {
						"type": "string"
					},
					"name": {
						"type": "string"
					},
					"role": {
						"type": "string"
					}
				}
			},
			"DisplayJob": {
				"type": "object",
				"description": "Returned Job",
				"required": [
					"id",
					"name",
					"job_type_id",
					"group_id",
					"notify_users",
					"run_every",
					"details"
				],
				"properties": {
					"custom_notification": {
						"type": ["string", "null"]
					},
					"details": {
						"$ref": "#/components/schemas/DisplayJobDetails"
					},
					"group_id": {
						"type": "string"
					},
					"id": {
						"type": "string"
					},
					"job_type_id": {
						"type": "string"
					},
					"last_scheduled": {
						"type": ["string", "null"],
						"format": "date-time"
					},
					"name": {
						"type": "string"
					},
					"notify_users": {
						"type": "boolean"
					},
					"run_every": {
						"type": "integer",
						"format": "int64",
						"default": 60
					}
				}
			},
			"DisplayJobDetails": {
				"oneOf": [
					{
						"type": "object",
						"required": ["http"],
						"properties": {
							"http": {
								"$ref": "#/components/schemas/DisplayJobDetailsHttp"
							}
						}
					},
					{
						"type": "object",
						"required": ["ping"],
						"properties": {
							"ping": {
								"$ref": "#/components/schemas/DisplayJobDetailsPing"
							}
						}
					},
					{
						"type": "string",
						"enum": ["undefined"]
					}
				],
				"description": "Returned Job Details"
			},
			"DisplayJobDetailsHttp": {
				"type": "object",
				"description": "Returned Job HTTP Detail",
				"required": ["id", "url"],
				"properties": {
					"id": {
						"type": "string"
					},
					"url": {
						"type": "string"
					}
				}
			},
			"DisplayJobDetailsPing": {
				"type": "object",
				"description": "Returned Job Ping Detail",
				"required": ["id", "host"],
				"properties": {
					"host": {
						"type": "string"
					},
					"id": {
						"type": "string"
					}
				}
			},
			"DisplayJobResultHttp": {
				"type": "object",
				"required": ["id", "ip_address", "status_code", "latency", "payload"],
				"properties": {
					"id": {
						"type": "string"
					},
					"ip_address": {
						"type": "string",
						"format": "cidr",
						"example": "192.0.2.5/32"
					},
					"latency": {
						"type": "integer",
						"format": "int32"
					},
					"payload": {
						"type": "array",
						"items": {
							"type": "integer",
							"format": "int32",
							"minimum": 0
						}
					},
					"status_code": {
						"type": "integer",
						"format": "int32"
					}
				}
			},
			"DisplayJobResultPing": {
				"type": "object",
				"required": ["id", "ip_address", "latency"],
				"properties": {
					"id": {
						"type": "string"
					},
					"ip_address": {
						"type": "string",
						"format": "cidr",
						"example": "192.0.2.5/32"
					},
					"latency": {
						"type": "integer",
						"format": "int32"
					}
				}
			},
			"DisplayJobRun": {
				"type": "object",
				"description": "Returned JobRun",
				"required": [
					"id",
					"job_id",
					"timestamp",
					"triggered_notification",
					"batch_id",
					"reachable",
					"details"
				],
				"properties": {
					"batch_id": {
						"type": "string"
					},
					"details": {
						"$ref": "#/components/schemas/DisplayJobRunDetails"
					},
					"id": {
						"type": "string"
					},
					"job_id": {
						"type": "string"
					},
					"reachable": {
						"type": "boolean"
					},
					"timestamp": {
						"type": "string",
						"format": "date-time"
					},
					"triggered_notification": {
						"type": "boolean"
					}
				}
			},
			"DisplayJobRunDetails": {
				"oneOf": [
					{
						"type": "object",
						"required": ["http"],
						"properties": {

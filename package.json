{
	"name": "guggr",
	"private": true,
	"type": "module",
	"version": "0.2.0",
	"packageManager": "pnpm@10.28.0",
	"scripts": {
		"check": "prettier --check .",
		"format": "prettier --write .",
		"gen": "pnpm gen:frontend-web-openapi-port && pnpm gen:helm-readme",
		"gen:frontend-web-openapi-port": "openapi-generator-cli generate -i api-service/openapi.json -g typescript-fetch -o frontend/web/src/api/gen && pnpm format",
		"gen:helm-readme": "readme-generator -v charts/guggr/values.yaml -r charts/guggr/README.md"
	},
	"devDependencies": {
		"@bitnami/readme-generator-for-helm": "github:bitnami/readme-generator-for-helm#3.0.1",
		"@openapitools/openapi-generator-cli": "^2.31.1",
		"prettier": "^3.8.3",
		"prettier-plugin-astro": "^0.14.1",
		"prettier-plugin-sql": "^0.20.0",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2"
	},
	"engines": {
		"node": "^24"
	}
}

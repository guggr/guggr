{
	"vhosts": [
		{
			"name": "/",
			"description": "Default virtual host",
			"metadata": {
				"description": "Default virtual host",
				"tags": [],
				"default_queue_type": "classic"
			},
			"tags": []
		}
	],
	"policies": [
		{
			"vhost": "/",
			"name": "default",
			"pattern": "(agent|scheduler)\\..+",
			"apply-to": "queues",
			"definition": {
				"delivery-limit": 5,
				"dead-letter-exchange": "dlx"
			},
			"priority": 10
		}
	],
	"exchanges": [
		{
			"name": "dlx",
			"vhost": "/",
			"type": "fanout",
			"durable": true,
			"auto_delete": false,
			"internal": false,
			"arguments": {}
		}
	],
	"queues": [
		{
			"name": "dlx.queue",
			"vhost": "/",
			"durable": true,
			"auto_delete": false,
			"arguments": {}
		},
		{
			"name": "scheduler.jobs",
			"vhost": "/",
			"durable": true,
			"auto_delete": false,
			"arguments": {
				"x-queue-type": "quorum"
			}
		},
		{
			"name": "agent.job_results",
			"vhost": "/",
			"durable": true,
			"auto_delete": false,
			"arguments": {
				"x-queue-type": "quorum"
			}
		}
	],
	"bindings": [
		{
			"source": "dlx",
			"vhost": "/",
			"destination": "dlx.queue",
			"destination_type": "queue",
			"routing_key": "dead-lettered",
			"arguments": {}
		}
	]
}
